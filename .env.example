PORT=3000
HOST=0.0.0.0

# OpenAI (interpretacao, triagem, raciocinio)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4o
OPENAI_FILTER_MODEL=gpt-4o-mini
OPENAI_ORDER_MODEL=gpt-4o

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://your-evolution-api.example.com
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=your-instance

# Regras do pedido
ORDER_CONFIDENCE_THRESHOLD=0.8
ORDER_STATE_TTL_MINUTES=30
ORDER_STORE_TTL_HOURS=72

# Redis (opcional). Se vazio, usa Map em memoria (dev). Em producao recomenda-se Redis
# para nao perder pedidos em andamento e pagamentos pendentes quando o processo reinicia.
REDIS_URL=
REDIS_KEY_PREFIX=pedidobot
ALLOWED_PHONES=
BODY_LIMIT_BYTES=26214400

# Token compartilhado entre backend, Apps Script e webhook de pagamento.
# Vai em X-Webhook-Token (ou ?token=). Se vazio, /order/finalize e /webhook/payment
# ficam expostos — nao deixe vazio em producao.
WEBHOOK_TOKEN=

# Google Sheets (Fase 3)
# Pode apontar para o arquivo credentials.json (path absoluto) ou colar o JSON inteiro aqui.
GOOGLE_SERVICE_ACCOUNT_KEY=/caminho/para/credentials.json
GOOGLE_SHEETS_ID=id-da-planilha
GOOGLE_SHEETS_RANGE=Pedidos!A:J

# Cobranca (Fase 4). Preencha APENAS um dos providers.
# BILLING_PROVIDER forca a escolha (asaas | mercadopago). Se vazio, o codigo decide por presenca de key.
BILLING_PROVIDER=
BILLING_DUE_DAYS=3

# Asaas
ASAAS_API_URL=https://api.asaas.com/v3
ASAAS_API_KEY=

# Mercado Pago
MERCADOPAGO_API_URL=https://api.mercadopago.com
MERCADOPAGO_ACCESS_TOKEN=

# NF-e (Fase 5). Preencha APENAS um dos providers.
INVOICE_PROVIDER=
INVOICE_EMITTER_CNPJ=
INVOICE_NATUREZA=Venda de mercadoria
INVOICE_CFOP=5102
INVOICE_DEFAULT_NCM=00000000
INVOICE_ICMS_CST=102

# Focus NFe
FOCUSNFE_API_URL=https://api.focusnfe.com.br
FOCUSNFE_API_KEY=

# eNotas
ENOTAS_API_URL=https://api.enotasgw.com.br
ENOTAS_API_KEY=
ENOTAS_COMPANY_ID=
